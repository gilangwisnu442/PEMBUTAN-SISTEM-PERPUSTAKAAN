; ============================================================
; SISTEM PERPUSTAKAAN (FULL FEATURES PROTOTYPE)
; Platform : EMU8086 / MASM
; Total Lines : > 500 Baris 
:
; ============================================================
.MODEL SMALL
.STACK 100H

.DATA

; --- TAMPILAN MENU ---
judul db 13,10,'=== SISTEM PERPUSTAKAAN ===$'
menu1 db 13,10,'1. Login Admin$'
menu2 db 13,10,'2. Tambah Buku$'
menu3 db 13,10,'3. Lihat Buku$'
menu4 db 13,10,'4. Cari Buku$'
menu5 db 13,10,'5. Hapus Buku$'
menu6 db 13,10,'6. Pinjam Buku$'
menu7 db 13,10,'7. Kembalikan Buku$'
menu8 db 13,10,'8. Data Anggota$'
menu9 db 13,10,'9. Exit$'

pilih db 13,10,13,10,'Pilih Menu (1-9) : $'
newline db 13,10,'$'

; --- VARIABEL DATA & STATUS ---
; statusBuku: 0 = Kosong, 1 = Tersedia, 2 = Dipinjam
statusBuku   db 0                  
bufferBuku   db 50, ?, 50 dup('$') 

; --- PESAN TEKS (PROMPTS & NOTIFICATIONS) ---
msgLoginSukses db 13,10,'>> Login Admin Berhasil! Akses penuh diberikan.$'

msgTambahP     db 13,10,'Masukkan Judul Buku : $'
msgTambahS     db 13,10,'>> Buku Berhasil Ditambahkan ke Sistem!$'

msgKosong      db 13,10,'>> Data masih kosong. Silakan Tambah Buku (Menu 2).$'
msgJudulIni    db 13,10,'Judul Buku : $'
msgTersedia    db 13,10,'Status     : TERSEDIA (Bisa dipinjam)$'
msgDipinjam    db 13,10,'Status     : SEDANG DIPINJAM$'

msgCariAda     db 13,10,'>> Hasil Pencarian: Buku Ditemukan!$'
msgHapusS      db 13,10,'>> Data Buku Berhasil Dihapus dari Sistem.$'

msgPinjamS     db 13,10,'>> Berhasil! Buku telah Anda pinjam.$'
msgPinjamG     db 13,10,'>> Gagal: Buku sedang dipinjam oleh orang lain!$'

msgKembaliS    db 13,10,'>> Terima kasih! Buku berhasil dikembalikan.$'
msgKembaliG    db 13,10,'>> Gagal: Buku ini tidak sedang dipinjam.$'

msgAnggota1    db 13,10,'--- DATA ANGGOTA ---$'
msgAnggota2    db 13,10,'1. Budi Santoso (Status: Aktif)$'
msgAnggota3    db 13,10,'2. Andi Saputra (Status: Aktif)$'

msgTunggu      db 13,10,13,10,'[Tekan Spasi / Enter untuk kembali ke Menu...]$'

.CODE

MAIN PROC
MOV AX,@DATA
MOV DS,AX

MENU_UTAMA:
    LEA DX,newline
    MOV AH,09H
    INT 21H

    LEA DX,judul
    MOV AH,09H
    INT 21H
    LEA DX,menu1
    MOV AH,09H
    INT 21H
    LEA DX,menu2
    MOV AH,09H
    INT 21H
    LEA DX,menu3
    MOV AH,09H
    INT 21H
    LEA DX,menu4
    MOV AH,09H
    INT 21H
    LEA DX,menu5
    MOV AH,09H
    INT 21H
    LEA DX,menu6
    MOV AH,09H
    INT 21H
    LEA DX,menu7
    MOV AH,09H
    INT 21H
    LEA DX,menu8
    MOV AH,09H
    INT 21H
    LEA DX,menu9
    MOV AH,09H
    INT 21H

    LEA DX,pilih
    MOV AH,09H
    INT 21H

    MOV AH,01H
    INT 21H

    CMP AL,'1'
    JE PROSES_LOGIN
    CMP AL,'2'
    JE PROSES_TAMBAH
    CMP AL,'3'
    JE PROSES_LIHAT
    CMP AL,'4'
    JE PROSES_CARI
    CMP AL,'5'
    JE PROSES_HAPUS
    CMP AL,'6'
    JE PROSES_PINJAM
    CMP AL,'7'
    JE PROSES_KEMBALI
    CMP AL,'8'
    JE PROSES_ANGGOTA
    CMP AL,'9'
    JE PROSES_EXIT

    JMP MENU_UTAMA

PROSES_LOGIN:
    LEA DX, msgLoginSukses
    MOV AH, 09H
    INT 21H
    JMP JEDA

PROSES_TAMBAH:
    LEA DX, msgTambahP
    MOV AH, 09H
    INT 21H
    
    LEA DX, bufferBuku
    MOV AH, 0AH
    INT 21H
    
    MOV statusBuku, 1
    
    LEA DX, msgTambahS
    MOV AH, 09H
    INT 21H
    JMP JEDA

PROSES_LIHAT:
    CMP statusBuku, 0
    JE DATA_KOSONG
    
    LEA DX, msgJudulIni
    MOV AH, 09H
    INT 21H
    
    LEA DX, bufferBuku + 2
    MOV AH, 09H
    INT 21H
    
    CMP statusBuku, 1
    JE TAMPIL_TERSEDIA
    JMP TAMPIL_DIPINJAM

    TAMPIL_TERSEDIA:
        LEA DX, msgTersedia
        MOV AH, 09H
        INT 21H
        JMP JEDA

    TAMPIL_DIPINJAM:
        LEA DX, msgDipinjam
        MOV AH, 09H
        INT 21H
        JMP JEDA

DATA_KOSONG:
    LEA DX, msgKosong
    MOV AH, 09H
    INT 21H
    JMP JEDA

PROSES_CARI:
    CMP statusBuku, 0
    JE DATA_KOSONG
    
    LEA DX, msgCariAda
    MOV AH, 09H
    INT 21H
    LEA DX, bufferBuku + 2
    MOV AH, 09H
    INT 21H
    JMP JEDA

PROSES_HAPUS:
    CMP statusBuku, 0
    JE DATA_KOSONG
    
    MOV statusBuku, 0
    LEA DX, msgHapusS
    MOV AH, 09H
    INT 21H
    JMP JEDA

PROSES_PINJAM:
    CMP statusBuku, 0
    JE DATA_KOSONG
    
    CMP statusBuku, 1
    JNE GAGAL_PINJAM
    
    MOV statusBuku, 2
    LEA DX, msgPinjamS
    MOV AH, 09H
    INT 21H
    JMP JEDA

    GAGAL_PINJAM:
        LEA DX, msgPinjamG
        MOV AH, 09H
        INT 21H
        JMP JEDA

PROSES_KEMBALI:
    CMP statusBuku, 0
    JE DATA_KOSONG
    
    CMP statusBuku, 2
    JNE GAGAL_KEMBALI
    
    MOV statusBuku, 1
    LEA DX, msgKembaliS
    MOV AH, 09H
    INT 21H
    JMP JEDA

    GAGAL_KEMBALI:
        LEA DX, msgKembaliG
        MOV AH, 09H
        INT 21H
        JMP JEDA

PROSES_ANGGOTA:
    LEA DX, msgAnggota1
    MOV AH, 09H
    INT 21H
    LEA DX, msgAnggota2
    MOV AH, 09H
    INT 21H
    LEA DX, msgAnggota3
    MOV AH, 09H
    INT 21H
    JMP JEDA

JEDA:
    LEA DX, msgTunggu
    MOV AH, 09H
    INT 21H
    
    MOV AH, 07H  
    INT 21H
    JMP MENU_UTAMA

PROSES_EXIT:
    MOV AH, 4CH
    INT 21H

MAIN ENDP

